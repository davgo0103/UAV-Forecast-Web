RewriteEngine On

# Proxy /caa-gis/* → https://dronegis.caa.gov.tw/*
RewriteRule ^caa-gis/(.*)$ https://dronegis.caa.gov.tw/$1 [P,L]

# Proxy /opentopodata/* → https://api.opentopodata.org/*
RewriteRule ^opentopodata/(.*)$ https://api.opentopodata.org/$1 [P,L]

# Proxy /opensky-auth/* → https://auth.opensky-network.org/*
RewriteRule ^opensky-auth/(.*)$ https://auth.opensky-network.org/$1 [P,L]

# SPA fallback — serve index.html for all non-file routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
