VITE_CWA_API_KEY=your_cwa_api_key_here
# OpenWeatherMap free API key — needed for cloud/wind map tiles
# Register at: https://openweathermap.org/api → One Call API (free tier)
VITE_OWM_API_KEY=your_owm_api_key_here
# Google Analytics
VITE_GA_ID=your_ga_measurement_id_here
# WeatherAPI.com fallback key — used when Open-Meteo hits daily rate limit
VITE_WEATHERAPI_KEY=your_weatherapi_key_here
# OpenSky Network OAuth2 — fallback when anonymous quota (400/day) is exhausted
VITE_OPENSKY_CLIENT_ID=your_opensky_client_id_here
VITE_OPENSKY_CLIENT_SECRET=your_opensky_client_secret_here